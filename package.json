{
  "name": "oscillator-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "scan:test": "npx tsx --env-file=.env.local scripts/scan-test.ts",
    "scan:dry": "cross-env DRY_RUN=true MA_PAIR=25,75 MARKET=JP npx tsx --env-file=.env.local scripts/scan.ts",
    "scan:run": "cross-env DRY_RUN=false MA_PAIR=25,75 MARKET=JP npx tsx --env-file=.env.local scripts/scan.ts",
    "fetch:full": "cross-env FETCH_MODE=full npx tsx --env-file=.env.local scripts/fetch-prices.ts",
    "fetch:diff": "cross-env FETCH_MODE=diff npx tsx --env-file=.env.local scripts/fetch-prices.ts",
    "fetch:dry": "cross-env FETCH_MODE=full DRY_RUN=true npx tsx --env-file=.env.local scripts/fetch-prices.ts",
    "fetch:date": "npx tsx --env-file=.env.local scripts/fetch-prices.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@types/ws": "^8.18.1",
    "lightweight-charts": "^5.2.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.21.0",
    "yahoo-finance2": "^3.15.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^3.2.4",
    "cross-env": "^7.0.3",
    "dotenv": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
